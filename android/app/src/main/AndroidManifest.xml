<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Phase 4: barcode scanning. Camera is optional so devices without one can still install. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <!-- Read suite connection config from the Dragonfly hub (BROKER.md Phase 1). Granted only
         because all suite apps share one signing key; harmless if Dragonfly isn't installed. -->
    <uses-permission android:name="com.dragonfly.permission.READ_SUITE_CONFIG" />
    <!-- API 30+ package visibility: needed to resolve Dragonfly's ContentProvider. -->
    <queries>
        <package android:name="com.dragonfly" />
    </queries>

    <application
        android:name=".PlateApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Plate"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Plate">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- AppAuth (BROKER.md Phase 2c) themes its AuthorizationManagementActivity as AppCompat but
             leaves RedirectUriReceiverActivity to inherit the app theme, which isn't AppCompat →
             it crashes on the redirect ("You need to use a Theme.AppCompat theme"). Force an
             AppCompat translucent theme on it (the same one AppAuth uses for its other activity). -->
        <activity
            android:name="net.openid.appauth.RedirectUriReceiverActivity"
            android:theme="@style/Theme.AppCompat.Translucent.NoTitleBar"
            tools:node="merge" />

        <!-- Home-screen macro glance (today's remaining calories + protein/carbs/fat), reads the
             last-known snapshot the app persisted — no network of its own. -->
        <receiver
            android:name=".widget.PlateWidgetReceiver"
            android:exported="true"
            android:label="Plate macros">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/plate_widget_info" />
        </receiver>
    </application>

</manifest>
