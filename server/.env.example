DATABASE_URL=postgresql+asyncpg://plate:plate@localhost:5432/plate
SECRET_KEY=change-me-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI coach + photo logging (LM Studio serving Gemma 3) ---
# Local-only inference — no hosted fallback. Mirrors Spotter's chat wiring (the
# OpenAI-compatible endpoint). Inside the Docker container `localhost` is the container,
# so for the Docker deployment use host.docker.internal (see deploy/README.md):
#   LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=google/gemma-3-12b
# Vision model for photo logging — defaults to the same multimodal Gemma 3.
LM_STUDIO_VISION_MODEL=google/gemma-3-12b
# Seconds to wait for an LM Studio response. The first request loads the model (cold
# start) before inference; raise this if initial AI setup times out on slow hardware.
LM_STUDIO_TIMEOUT=60

# --- External food data sources (server-side only, never shipped in the APK) ---
# USDA FoodData Central key (free, api.data.gov). Unset ⇒ live USDA search is skipped
# (local cache + Open Food Facts still work). Live calls happen only on a cache miss.
# USDA_API_KEY=change-me-to-your-fdc-api-key
# OFF requires a descriptive User-Agent identifying the app + a contact.
# OFF_USER_AGENT=Plate/0.1.0 (you@example.com)
# Master switch for live external lookups on a cache miss (local-cache search still works when off).
# FOOD_SEARCH_LIVE=true

# --- Public deployment hardening (safe to leave unset for local/trusted-network use) ---
# Require this code on /auth/register so the public hostname can't be self-registered against.
# REGISTRATION_INVITE_CODE=change-me-to-a-shared-secret
# Trust forwarded client IPs for per-user rate limiting. Enable ONLY behind a trusted proxy
# (Cloudflare Tunnel / nginx); also run uvicorn with --proxy-headers --forwarded-allow-ips='*'.
# TRUST_PROXY=true
# Send Strict-Transport-Security (enable only when served over HTTPS, e.g. via Cloudflare).
# HSTS_ENABLED=true
# Expose interactive API docs at /docs. Set false to hide them on a public deployment.
# DOCS_ENABLED=true

# --- Spotter-awareness (reads the user's training status from Spotter's GET /workouts) ---
# Base URL of Spotter's API. Unset ⇒ the integration is disabled (never a training day).
# SPOTTER_BASE_URL=https://spotter.example.com
# Shared HMAC secret for the cross-app token Plate mints (must MATCH Spotter's CROSS_APP_SECRET).
# Separate from SECRET_KEY so a normal Plate token can't reach the cross-app surface.
# CROSS_APP_SECRET=change-me-to-a-shared-secret-matching-spotter

# --- Password reset email (SMTP) ---
# Without these, reset codes are only printed to the server log (useful for local dev).
# Gmail: create a 16-char App Password at myaccount.google.com/apppasswords (requires 2FA).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=you@gmail.com
# For Outlook / Yahoo (port 465 SSL) set SMTP_USE_SSL=true and SMTP_PORT=465.
# SMTP_USE_SSL=false
